# Copy to analyzer/.env on the server (gitignored). Only ANTHROPIC_API_KEY is
# required here. PROM_URL / LOKI_URL are wired in docker-compose.yml (internal
# Docker hostnames) and must NOT be set in this file.
#
# To override a tunable, uncomment its assignment line. Keep the value alone on
# the line — do not add trailing inline comments (some env_file parsers include
# them in the value, which breaks the integer settings).

# --- Required ---------------------------------------------------------------
# Used by the webhook service's Claude calls.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional tunables (defaults shown) -------------------------------------

# Claude model used for investigations.
# ANALYZER_MODEL=claude-sonnet-4-6

# Max tool-call rounds per investigation.
# MAX_TOOL_TURNS=8

# Max output tokens per model turn.
# MAX_TOKENS=1024

# Seconds before the same firing alert is investigated again.
# DEDUP_TTL=3600

# Seconds per Prometheus/Loki request.
# HTTP_TIMEOUT=30

# --- Advanced (defaults match the compose volume mounts; rarely changed) -----

# Path to the shared bearer secret (also Alertmanager's credentials_file).
# WEBHOOK_TOKEN_FILE=/run/analyzer_token

# Path to the Discord webhook URL.
# DISCORD_WEBHOOK_FILE=/run/discord_webhook

# Inline bearer token — only for local runs without the mounted token file.
# The service refuses all requests (503) if no token is configured at all.
# WEBHOOK_TOKEN=
